#!/bin/sh

CXX="${CXX:-g++}"
CXXFLAGS="${CXXFLAGS:--std=c++17 -O2 -Wall -Wextra}"
PREFIX="/usr/local"

while [ $# -gt 0 ]; do
    case "$1" in
        --prefix=*) PREFIX="${1#*=}" ;;
        --cxx=*) CXX="${1#*=}" ;;
        *) echo "Unknown option: $1"; exit 1 ;;
    esac
    shift
done

echo "Checking for C++ compiler... $CXX"
if ! command -v "$CXX" >/dev/null 2>&1; then
    echo "Error: C++ compiler '$CXX' not found."
    exit 1
fi

echo "Generating Makefile..."
sed -e "s|@CXX@|${CXX}|g" \
    -e "s|@CXXFLAGS@|${CXXFLAGS}|g" \
    -e "s|@PREFIX@|${PREFIX}|g" \
    Makefile.in > Makefile

echo "Configure complete. Run 'make' to build."
